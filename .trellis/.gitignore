# Developer identity (local only)
.developer

# Current task pointer (each dev works on different task)
.current-task

# Ralph Loop state file
.ralph-state.json

# Agent runtime files
.agents/
.agent-log
.session-id

# Task directory runtime files
.plan-log

# Atomic update temp files
*.tmp

# Update backup directories
.backup-*

# Conflict resolution temp files
*.new

# Python cache
**/__pycache__/
**/*.pyc

# Per-developer workspace contents (personal session journals)
# Keep workspace/index.md (shared registry) but ignore each dev's directory
workspace/*/

# Backup workspaces created by trellis update
backup/
